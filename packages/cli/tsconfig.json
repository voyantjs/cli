{
  "extends": "@voyantjs/cli-tsconfig/base.json",
  "compilerOptions": {
    "composite": false,
    "outDir": "dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  },
  "include": ["src/**/*", "tests/**/*", "bin/**/*"],
  "exclude": ["src/**/__tests__/**/*"]
}
