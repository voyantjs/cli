{
  "name": "@voyantjs/cli",
  "version": "0.24.0",
  "license": "Apache-2.0",
  "description": "Unified CLI for the Voyant open-source framework and the Voyant Cloud platform.",
  "type": "module",
  "bin": {
    "voyant": "./bin/voyant.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./drizzle": "./src/drizzle.ts",
    "./commands/generate-module": "./src/commands/generate-module.ts",
    "./commands/generate-link": "./src/commands/generate-link.ts",
    "./commands/config": "./src/commands/config.ts",
    "./commands/admin-generate": "./src/commands/admin-generate.ts",
    "./commands/admin-doctor": "./src/commands/admin-doctor.ts",
    "./commands/db-sync-links": "./src/commands/db-sync-links.ts",
    "./commands/db-schemas": "./src/commands/db-schemas.ts",
    "./commands/exec": "./src/commands/exec.ts",
    "./commands/new": "./src/commands/new.ts",
    "./commands/dev": "./src/commands/dev.ts",
    "./commands/workflows": "./src/commands/workflows-command.ts",
    "./commands/login": "./src/commands/login.ts",
    "./commands/logout": "./src/commands/logout.ts",
    "./commands/whoami": "./src/commands/whoami.ts",
    "./commands/vaults": "./src/commands/vaults.ts",
    "./commands/secrets": "./src/commands/secrets.ts",
    "./lib/strings": "./src/lib/strings.ts",
    "./lib/args": "./src/lib/args.ts",
    "./lib/config-loader": "./src/lib/config-loader.ts",
    "./lib/resolve-schemas": "./src/lib/resolve-schemas.ts",
    "./lib/credentials": "./src/lib/credentials.ts",
    "./lib/cloud-client": "./src/lib/cloud-client.ts",
    "./lib/device-code": "./src/lib/device-code.ts",
    "./lib/voyant-version": "./src/lib/voyant-version.ts"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome check --write src tests",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyantjs/cloud-sdk": "^0.6.1",
    "@voyantjs/core": "^0.18.0",
    "@voyantjs/workflows": "^0.18.0",
    "@voyantjs/workflows-orchestrator": "^0.18.0",
    "@voyantjs/workflows-orchestrator-node": "^0.18.0",
    "esbuild": "^0.28.0",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@voyantjs/cli-tsconfig": "workspace:*",
    "typescript": "5.9.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
